# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUVwxyz

# GitHub personal access token (needs repo + workflow scopes)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GitHub repository (owner/repo)
GITHUB_REPO=SpaceFex/autotests

# Workflow filename
GITHUB_WORKFLOW=aio-tests-integration.yml

# Allowed Telegram usernames or user IDs (comma-separated).
# Leave empty to allow EVERYONE who can write to the bot.
# Example: ALLOWED_USERS=john_doe,jane_doe,123456789
ALLOWED_USERS=
